# Notion API
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Server
HOST=127.0.0.1
PORT=8000

# Database (SQLAlchemy URL)
# 기본값: 로컬 SQLite (설정 안 하면 자동으로 data/quest.db 사용)
# SQLite:     sqlite:///./data/quest.db
# PostgreSQL: postgresql://user:password@localhost:5432/quest_widget
# MySQL:      mysql+pymysql://user:password@localhost:3306/quest_widget
DATABASE_URL=sqlite:///./data/quest.db

# SSH 터널 (원격 PostgreSQL 등 SSH를 통해 접속할 때)
# SSH_HOST를 설정하면 자동으로 SSH 터널을 열고 DB에 연결
# SSH_HOST=your-server.com
# SSH_PORT=22
# SSH_USER=your_ssh_username
# SSH_PASSWORD=your_ssh_password
# SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_DB_HOST=127.0.0.1
# SSH_DB_PORT=5432